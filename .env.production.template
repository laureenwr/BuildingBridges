# Contact form email delivery
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_USER="your_username"
SMTP_PASS="your_password"
EMAIL_FROM="Building Bridges <no-reply@your-domain.com>"

# Logging
LOG_LEVEL="info"
